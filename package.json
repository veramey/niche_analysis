{
  "name": "tenderguru-integration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal TenderGuru API v2.3 integration client",
  "scripts": {
    "tg": "node src/cli.js",
    "smoke": "node src/cli.js get --param mode=regions --limit-output 1200",
    "analyze-docs": "node scripts/analyze-tender-docs.js",
    "find-tz": "node scripts/find-tz-candidates.js",
    "export-missing-doc-links": "node scripts/export-missing-doc-links.js",
    "download-find-tz": "node scripts/download-and-find-tz.js",
    "dashboard": "node scripts/serve-analysis.js",
    "analyze-info": "node scripts/analyze-info-text.js",
    "patch-cards": "node scripts/patch-cards-add-info.js",
    "classify-spheres": "node scripts/classify-tender-spheres-llm.js",
    "build": "node scripts/build-static.js",
    "fetch-missing-docs": "node scripts/fetch-missing-docs.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
